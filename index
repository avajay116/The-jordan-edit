<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="The Jordan Edit — Luxury event styling, creative direction, and curated experiences. Based in Orlando, Florida.">
<meta property="og:title" content="The Jordan Edit">
<meta property="og:description" content="Luxury event styling and creative direction for the moments that matter.">
<meta property="og:image" content="https://images.unsplash.com/photo-1519225421980-715cb0215aed?w=1200">
<title>The Jordan Edit</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  /* ── RESET + ROOT ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --ivory:     #FAF7F2;
    --ivory-deep:#F0E8DC;
    --caramel:   #C49A6C;
    --caramel-lt:#E8D5B0;
    --mocha:     #6B4E3D;
    --mocha-lt:  #9B8A7A;
    --black:     #1a1a18;
    --border:    rgba(196,154,108,0.18);
    --border-md: rgba(196,154,108,0.35);
    --serif:     'Cormorant Garamond', Georgia, serif;
    --sans:      'DM Sans', system-ui, sans-serif;
    --ease:      cubic-bezier(0.4,0,0.2,1);
  }
  html { scroll-behavior: smooth; font-size: 16px; }
  body {
    font-family: var(--sans);
    background: var(--ivory);
    color: var(--black);
    line-height: 1.7;
    overflow-x: hidden;
  }
  img { max-width: 100%; display: block; }
  a { color: inherit; text-decoration: none; }
  ::selection { background: var(--caramel-lt); }

  /* ── TYPOGRAPHY ── */
  .serif { font-family: var(--serif); }
  .label {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--caramel);
  }
  .section-title {
    font-family: var(--serif);
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--mocha);
    margin-bottom: 1rem;
  }
  .section-sub {
    font-size: 1rem;
    color: var(--mocha-lt);
    font-style: italic;
    max-width: 520px;
    line-height: 1.8;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 1.2rem 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(250,247,242,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 0.5px solid var(--border);
    transition: all 0.3s var(--ease);
  }
  .nav-brand {
    font-family: var(--serif);
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--mocha);
    letter-spacing: 0.03em;
  }
  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }
  .nav-links a {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--mocha-lt);
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--caramel); }
  .nav-cta {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 8px 22px;
    border: 0.5px solid var(--caramel);
    border-radius: 30px;
    color: var(--caramel);
    letter-spacing: 0.05em;
    transition: all 0.25s var(--ease);
  }
  .nav-cta:hover {
    background: var(--caramel);
    color: var(--ivory);
  }
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 4px;
  }
  .hamburger span {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--mocha);
    transition: all 0.3s;
  }
  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--ivory);
    z-index: 99;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
  }
  .mobile-menu.open { display: flex; }
  .mobile-menu a {
    font-family: var(--serif);
    font-size: 2rem;
    color: var(--mocha);
    font-weight: 400;
  }
  .mobile-close {
    position: absolute;
    top: 1.5rem; right: 2rem;
    font-size: 1.5rem;
    background: none;
    border: none;
    color: var(--mocha);
    cursor: pointer;
    font-family: var(--serif);
  }

  /* ── SECTIONS ── */
  section { padding: 6rem 2.5rem; max-width: 1200px; margin: 0 auto; }
  .full-bleed { max-width: none; }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 2rem;
    position: relative;
    overflow: hidden;
    background: var(--ivory);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('https://images.unsplash.com/photo-1519225421980-715cb0215aed?w=1400&q=80');
    background-size: cover;
    background-position: center 40%;
    opacity: 0.12;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 700px;
    opacity: 0;
    transform: translateY(24px);
    animation: fadeUp 1.1s var(--ease) 0.3s forwards;
  }
  .hero-label {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--caramel);
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.9s var(--ease) 0.6s forwards;
  }
  .hero-title {
    font-family: var(--serif);
    font-size: clamp(3rem, 9vw, 6.5rem);
    font-weight: 300;
    color: var(--mocha);
    line-height: 1.0;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }
  .hero-sub {
    font-size: 1.05rem;
    color: var(--mocha-lt);
    font-style: italic;
    margin-bottom: 2.5rem;
    line-height: 1.8;
  }
  .hero-divider {
    width: 60px;
    height: 0.5px;
    background: var(--caramel-lt);
    margin: 0 auto 2.5rem;
  }
  .btn-primary {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 14px 40px;
    border: 0.5px solid var(--caramel);
    border-radius: 40px;
    color: var(--caramel);
    transition: all 0.3s var(--ease);
  }
  .btn-primary:hover {
    background: var(--caramel);
    color: var(--ivory);
    transform: translateY(-1px);
  }
  .btn-secondary {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--mocha-lt);
    margin-left: 1.5rem;
    transition: color 0.2s;
  }
  .btn-secondary:hover { color: var(--caramel); }
  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    opacity: 0;
    animation: fadeIn 1s var(--ease) 1.5s forwards;
  }
  .hero-scroll span { font-size: 0.6rem; letter-spacing: 0.12em; color: var(--mocha-lt); text-transform: uppercase; }
  .scroll-line { width: 0.5px; height: 40px; background: var(--caramel-lt); animation: scrollPulse 2s infinite; }

  /* ── INTRO STRIP ── */
  .intro-strip {
    background: var(--ivory-deep);
    border-top: 0.5px solid var(--border);
    border-bottom: 0.5px solid var(--border);
    padding: 2rem 2.5rem;
    display: flex;
    justify-content: center;
    gap: 4rem;
    flex-wrap: wrap;
    text-align: center;
  }
  .strip-item { }
  .strip-num {
    font-family: var(--serif);
    font-size: 2rem;
    color: var(--caramel);
    line-height: 1;
    margin-bottom: 4px;
  }
  .strip-label { font-size: 0.72rem; color: var(--mocha-lt); letter-spacing: 0.04em; }

  /* ── ABOUT ── */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }
  .about-img {
    aspect-ratio: 3/4;
    background: var(--ivory-deep);
    border: 0.5px solid var(--border-md);
    border-radius: 4px;
    overflow: hidden;
    position: relative;
  }
  .about-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }
  .about-img-caption {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--ivory);
    text-transform: uppercase;
    background: rgba(107,78,61,0.7);
    padding: 4px 10px;
    border-radius: 20px;
  }
  .about-content { padding-right: 1rem; }
  .about-quote {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-style: italic;
    color: var(--caramel);
    line-height: 1.5;
    margin: 1.5rem 0;
    padding-left: 1.5rem;
    border-left: 1px solid var(--caramel-lt);
  }
  .body-text { font-size: 0.9rem; color: var(--mocha-lt); line-height: 1.9; margin-bottom: 1rem; }
  .words-row { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 1.5rem; }
  .word-tag {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    padding: 4px 14px;
    border: 0.5px solid var(--border-md);
    border-radius: 20px;
    color: var(--mocha);
    background: var(--ivory-deep);
  }

  /* ── SERVICES ── */
  .services-section {
    background: var(--black);
    padding: 6rem 2.5rem;
  }
  .services-inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .services-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .services-section .label { color: var(--caramel-lt); opacity: 0.7; }
  .services-section .section-title { color: var(--ivory); margin-bottom: 0; }
  .services-section .section-sub { color: rgba(250,247,242,0.5); }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    overflow: hidden;
  }
  .service-card {
    padding: 2.5rem 2rem;
    background: rgba(26,26,24,0.98);
    transition: background 0.3s var(--ease);
    cursor: default;
  }
  .service-card:hover { background: rgba(196,154,108,0.08); }
  .service-num {
    font-family: var(--serif);
    font-size: 3rem;
    color: var(--caramel);
    opacity: 0.3;
    line-height: 1;
    margin-bottom: 1.5rem;
  }
  .service-name {
    font-family: var(--serif);
    font-size: 1.4rem;
    color: var(--ivory);
    font-weight: 400;
    margin-bottom: 1rem;
    line-height: 1.3;
  }
  .service-desc { font-size: 0.82rem; color: rgba(250,247,242,0.55); line-height: 1.8; margin-bottom: 1.5rem; }
  .service-includes { margin-bottom: 1.5rem; }
  .service-tag {
    display: inline-block;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    padding: 3px 10px;
    border: 0.5px solid rgba(196,154,108,0.3);
    border-radius: 20px;
    color: var(--caramel-lt);
    margin-right: 5px;
    margin-bottom: 5px;
  }
  .service-price {
    font-size: 0.78rem;
    color: var(--caramel);
    font-weight: 500;
    padding-top: 1rem;
    border-top: 0.5px solid rgba(255,255,255,0.07);
  }

  /* ── PROCESS ── */
  .process-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 3rem;
  }
  .process-step {
    padding: 2rem;
    border: 0.5px solid var(--border);
    border-radius: 4px;
    background: #fff;
    margin: -1px;
  }
  .process-step:hover { background: var(--ivory-deep); transition: background 0.2s; }
  .step-num {
    font-family: var(--serif);
    font-size: 2.5rem;
    color: var(--caramel-lt);
    line-height: 1;
    margin-bottom: 1rem;
  }
  .step-title { font-size: 0.9rem; font-weight: 500; color: var(--mocha); margin-bottom: 6px; }
  .step-desc { font-size: 0.8rem; color: var(--mocha-lt); line-height: 1.7; }

  /* ── FOR REALTORS ── */
  .realtor-section {
    background: var(--ivory-deep);
    border-top: 0.5px solid var(--border);
    border-bottom: 0.5px solid var(--border);
  }
  .realtor-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .realtor-cards { display: flex; flex-direction: column; gap: 10px; }
  .realtor-card {
    background: #fff;
    border: 0.5px solid var(--border-md);
    border-left: 2.5px solid var(--caramel);
    border-radius: 0 8px 8px 0;
    padding: 1.25rem 1.5rem;
    transition: border-left-color 0.2s;
  }
  .realtor-card:hover { border-left-color: var(--mocha); }
  .realtor-card-title { font-size: 0.88rem; font-weight: 500; color: var(--mocha); margin-bottom: 6px; }
  .realtor-card-body { font-size: 0.8rem; color: var(--mocha-lt); line-height: 1.7; }

  /* ── TESTIMONIAL ── */
  .testimonial-section {
    text-align: center;
    padding: 5rem 2.5rem;
    max-width: 800px;
    margin: 0 auto;
  }
  .testimonial-quote {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 300;
    color: var(--mocha);
    font-style: italic;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  .testimonial-attr { font-size: 0.75rem; color: var(--mocha-lt); letter-spacing: 0.08em; text-transform: uppercase; }

  /* ── FAQ ── */
  .faq-grid { max-width: 720px; margin: 3rem auto 0; }
  .faq-item {
    border-bottom: 0.5px solid var(--border-md);
    padding: 1.25rem 0;
    cursor: pointer;
  }
  .faq-item:first-child { border-top: 0.5px solid var(--border-md); }
  .faq-q {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--mocha);
    gap: 1rem;
  }
  .faq-arrow {
    font-size: 1.2rem;
    color: var(--caramel);
    transition: transform 0.3s var(--ease);
    flex-shrink: 0;
    font-family: var(--serif);
  }
  .faq-item.open .faq-arrow { transform: rotate(45deg); }
  .faq-a {
    font-size: 0.82rem;
    color: var(--mocha-lt);
    line-height: 1.8;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s var(--ease), padding 0.3s;
  }
  .faq-item.open .faq-a { max-height: 200px; padding-top: 0.75rem; }

  /* ── CONTACT ── */
  .contact-section {
    background: var(--mocha);
    padding: 6rem 2.5rem;
    text-align: center;
  }
  .contact-inner { max-width: 600px; margin: 0 auto; }
  .contact-section .label { color: var(--caramel-lt); opacity: 0.7; }
  .contact-title {
    font-family: var(--serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 300;
    color: var(--ivory);
    margin: 1rem 0 0.75rem;
    line-height: 1.2;
  }
  .contact-sub { font-size: 0.9rem; color: rgba(250,247,242,0.55); font-style: italic; margin-bottom: 2.5rem; }
  .contact-form { display: flex; flex-direction: column; gap: 12px; text-align: left; margin-bottom: 1.5rem; }
  .contact-form input, .contact-form textarea, .contact-form select {
    width: 100%;
    padding: 14px 18px;
    background: rgba(250,247,242,0.06);
    border: 0.5px solid rgba(250,247,242,0.2);
    border-radius: 6px;
    color: var(--ivory);
    font-family: var(--sans);
    font-size: 0.85rem;
    outline: none;
    transition: border-color 0.2s;
    -webkit-appearance: none;
  }
  .contact-form input::placeholder, .contact-form textarea::placeholder { color: rgba(250,247,242,0.35); }
  .contact-form input:focus, .contact-form textarea:focus, .contact-form select:focus { border-color: var(--caramel); }
  .contact-form select option { background: var(--mocha); color: var(--ivory); }
  .contact-form textarea { min-height: 110px; resize: vertical; }
  .contact-submit {
    width: 100%;
    padding: 15px;
    background: var(--caramel);
    color: var(--ivory);
    border: none;
    border-radius: 40px;
    font-family: var(--sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.25s var(--ease);
    margin-top: 4px;
  }
  .contact-submit:hover { background: var(--caramel-lt); color: var(--mocha); transform: translateY(-1px); }
  .contact-social {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 0.5px solid rgba(250,247,242,0.12);
  }
  .contact-social a { font-size: 0.72rem; color: rgba(250,247,242,0.45); letter-spacing: 0.08em; text-transform: uppercase; transition: color 0.2s; }
  .contact-social a:hover { color: var(--caramel); }

  /* ── FOOTER ── */
  footer {
    background: var(--black);
    padding: 2rem 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .footer-brand { font-family: var(--serif); font-size: 1.1rem; color: var(--ivory); opacity: 0.6; }
  .footer-tagline { font-size: 0.68rem; color: rgba(250,247,242,0.3); font-style: italic; }
  .footer-links { display: flex; gap: 1.5rem; }
  .footer-links a { font-size: 0.68rem; color: rgba(250,247,242,0.35); letter-spacing: 0.06em; text-transform: uppercase; transition: color 0.2s; }
  .footer-links a:hover { color: var(--caramel); }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeIn { to { opacity: 1; } }
  @keyframes scrollPulse {
    0%, 100% { opacity: 1; transform: scaleY(1); }
    50% { opacity: 0.4; transform: scaleY(0.6); }
  }
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s var(--ease), transform 0.7s var(--ease);
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links, .nav-cta { display: none; }
    .hamburger { display: flex; }
    section { padding: 4rem 1.5rem; }
    .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .about-img { aspect-ratio: 4/3; }
    .services-grid { grid-template-columns: 1fr; }
    .process-grid { grid-template-columns: 1fr 1fr; }
    .realtor-grid { grid-template-columns: 1fr; gap: 2rem; }
    .services-header { flex-direction: column; align-items: flex-start; }
    .contact-section { padding: 4rem 1.5rem; }
    footer { flex-direction: column; text-align: center; }
    .footer-links { justify-content: center; }
    .intro-strip { gap: 2rem; }
  }
  @media (max-width: 600px) {
    .process-grid { grid-template-columns: 1fr; }
    .hero-title { font-size: 3.2rem; }
    .btn-secondary { display: block; margin: 1rem 0 0; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="#" class="nav-brand">The Jordan Edit</a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#services">Services</a></li>
    <li><a href="#process">Process</a></li>
    <li><a href="#realtors">Realtors</a></li>
    <li><a href="#faq">FAQ</a></li>
  </ul>
  <a href="#contact" class="nav-cta">Enquire</a>
  <button class="hamburger" onclick="toggleMenu()" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- MOBILE MENU -->
<div class="mobile-menu" id="mobileMenu">
  <button class="mobile-close" onclick="toggleMenu()">×</button>
  <a href="#about" onclick="toggleMenu()">About</a>
  <a href="#services" onclick="toggleMenu()">Services</a>
  <a href="#process" onclick="toggleMenu()">Process</a>
  <a href="#realtors" onclick="toggleMenu()">Realtors</a>
  <a href="#faq" onclick="toggleMenu()">FAQ</a>
  <a href="#contact" onclick="toggleMenu()">Enquire</a>
</div>

<!-- HERO -->
<section class="hero full-bleed">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <div class="hero-label">Orlando, Florida · Est. 2025</div>
    <h1 class="hero-title">The Jordan<br>Edit</h1>
    <div class="hero-divider"></div>
